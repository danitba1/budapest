{
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health"
    },
    {
      "source": "/api/tasks",
      "destination": "/api/tasks"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/server"
    }
  ],
  "functions": {
    "api/health.js": {
      "maxDuration": 60,
      "includeFiles": "server/connection-config.js"
    },
    "api/tasks.js": {
      "maxDuration": 60,
      "includeFiles": "server/trip-tasks-store.js"
    },
    "api/server.js": {
      "maxDuration": 60,
      "includeFiles": "server/**/*.js"
    }
  }
}
